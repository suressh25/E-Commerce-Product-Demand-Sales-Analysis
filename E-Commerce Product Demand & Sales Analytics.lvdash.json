                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "measure(total_units_sold)",
                  "format": {
                    "type": "number-plain",
                    "abbreviation": "compact",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 0
