                  "scale": {
                    "type": "categorical"
                  }
                }
              }
            }
          },
          "position": {
            "x": 6,
            "y": 2,
            "width": 6,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "category_revenue",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "gold_category_revenue",
                  "fields": [
                    {
                      "name": "measure(total_category_revenue)",
                      "expression": "MEASURE(`total_category_revenue`)"
