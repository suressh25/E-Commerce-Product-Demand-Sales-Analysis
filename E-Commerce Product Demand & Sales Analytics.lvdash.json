{
  "datasets": [
    {
      "name": "gold_category_revenue",
      "displayName": "Gold Category Revenue",
      "config": {
        "version": "1.1",
        "source": "databricks_cat.gold.CategoryRevenue",
        "dimensions": [
          {
            "name": "category",
            "expr": "category"
          }
        ],
        "measures": [
          {
            "name": "total_category_revenue",
            "expr": "SUM(total_category_revenue)"
          },
          {
            "name": "total_category_units",
            "expr": "SUM(total_category_units)"
          },
          {
            "name": "avg_category_return_rate",
            "expr": "AVG(avg_category_return_rate)"
          },
          {
            "name": "distinct_products",
            "expr": "SUM(distinct_products)"
          }
        ]
      }
    },
    {
      "name": "gold_forecast_30d",
      "displayName": "Gold Forecast 30D",
      "config": {
        "version": "1.1",
        "source": "SELECT forecast_date, category, SUM(forecasted_units) AS forecasted_units FROM databricks_cat.gold.DemandForecast_30D GROUP BY forecast_date, category ORDER BY forecast_date ASC\n",
        "dimensions": [
          {
            "name": "forecast_date",
            "expr": "forecast_date"
          },
          {
            "name": "category",
            "expr": "category"
          }
        ],
        "measures": [
          {
            "name": "forecasted_units",
            "expr": "SUM(forecasted_units)"
          }
        ]
      }
    },
    {
      "name": "gold_top_sellers",
      "displayName": "Gold Top Sellers",
      "config": {
        "version": "1.1",
        "source": "SELECT * FROM databricks_cat.gold.ProductPerformance WHERE product_label = 'TOP_SELLER' ORDER BY total_revenue DESC LIMIT 10\n",
        "dimensions": [
          {
            "name": "product_name",
            "expr": "product_name"
          },
          {
            "name": "category",
            "expr": "category"
          },
          {
            "name": "brand",
            "expr": "brand"
          }
        ],
        "measures": [
          {
            "name": "total_units_sold",
            "expr": "SUM(total_units_sold)"
          },
          {
            "name": "total_revenue",
            "expr": "SUM(total_revenue)"
          }
        ]
      }
    },
    {
      "name": "gold_slow_movers",
      "displayName": "Gold Slow Movers",
      "config": {
        "version": "1.1",
        "source": "SELECT * FROM databricks_cat.gold.ProductPerformance WHERE product_label = 'SLOW_MOVER' ORDER BY total_units_sold ASC, total_revenue ASC LIMIT 10\n",
        "dimensions": [
          {
            "name": "product_name",
            "expr": "product_name"
          },
          {
            "name": "category",
            "expr": "category"
          },
          {
            "name": "brand",
            "expr": "brand"
          }
        ],
        "measures": [
          {
            "name": "total_units_sold",
            "expr": "SUM(total_units_sold)"
          },
          {
            "name": "total_revenue",
            "expr": "SUM(total_revenue)"
          }
        ]
      }
    },
    {
      "name": "gold_demand_trend",
      "displayName": "Gold Demand Trend",
      "config": {
        "version": "1.1",
        "source": "SELECT date_trunc('WEEK', order_date) AS week_start, category, SUM(units_sold) AS weekly_units_sold FROM databricks_cat.gold.DailyDemand GROUP BY date_trunc('WEEK', order_date), category ORDER BY week_start ASC\n",
        "dimensions": [
          {
            "name": "week_start",
            "expr": "week_start"
          },
          {
            "name": "category",
            "expr": "category"
          }
        ],
        "measures": [
          {
            "name": "weekly_units_sold",
            "expr": "SUM(weekly_units_sold)"
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "57b34758",
      "displayName": "Sales & Demand Overview",
      "layout": [
        {
          "widget": {
            "name": "project_header",
            "multilineTextboxSpec": {
              "lines": [
                "## E-Commerce Product Demand & Sales Analysis\n",
                "Gold-layer product demand dashboard focused on top sellers, slow movers, category revenue, historical demand trend, and 30-day forecast."
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 12,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "top_sellers",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "gold_top_sellers",
                  "fields": [
                    {
                      "name": "product_name",
                      "expression": "`product_name`"
                    },
                    {
                      "name": "measure(total_revenue)",
                      "expression": "MEASURE(`total_revenue`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "showTitle": true,
                "title": "Top Selling Products"
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "product_name",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "measure(total_revenue)",
                  "format": {
                    "type": "number-currency",
                    "currencyCode": "USD",
                    "abbreviation": "compact",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 0
                    }
                  },
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "color": {
                  "fieldName": "product_name",
                  "legend": {
                    "hide": true
                  },
                  "scale": {
                    "type": "categorical"
                  }
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 6,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "slow_movers",
